{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/c3qo/samx-registry/blob/main/schemas/formula.v1.schema.json",
  "title": "SAMX Formula",
  "description": "Schema for SAMX registry formula YAML files. Derived from the Zod schema in @samx/schemas.",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "source", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1,
      "description": "Formula schema version. Must be 1."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^/\\\\]+/[^/\\\\]+$",
      "description": "Formula identifier in <owner>/<repo> format. Must match the file path under formulas/."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable formula name."
    },
    "description": {
      "type": "string",
      "description": "Concise, user-facing description of what this formula provides."
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Optional URL to the project homepage or documentation."
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "description": "Optional SPDX license identifier for the upstream package."
    },
    "source": {
      "description": "Where the package source comes from.",
      "oneOf": [
        { "$ref": "#/$defs/gitSource" },
        { "$ref": "#/$defs/virtualSource" }
      ]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" },
      "description": "Skills, agents, and MCP servers exposed by this package."
    },
    "requirements": {
      "$ref": "#/$defs/requirements",
      "default": { "env": [] }
    },
    "hooks": {
      "$ref": "#/$defs/hooks",
      "default": { "mode": "explicit", "entries": [] }
    },
    "advisories": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisory" },
      "default": [],
      "description": "Security or behavioral advisories for this package."
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "description": "A relative path. Must not start with / or contain .. segments.",
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "^[a-zA-Z]:[\\\\/]" },
          { "pattern": "(^|/)\\.\\.(/|$)" }
        ]
      }
    },
    "hexRevision": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$|^[a-f0-9]{64}$",
      "description": "A locked 40- or 64-character lowercase hex commit SHA."
    },
    "gitSource": {
      "type": "object",
      "required": ["type", "url", "revision"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "git" },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Git clone URL. Must use https, git, ssh, or file protocol."
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "Optional branch or tag name used to resolve the revision."
        },
        "revision": {
          "$ref": "#/$defs/hexRevision"
        }
      }
    },
    "virtualSource": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "virtual" },
        "origin": {
          "oneOf": [
            {
              "type": "object",
              "required": ["type", "url"],
              "additionalProperties": false,
              "properties": {
                "type": { "const": "remote" },
                "url": { "type": "string", "format": "uri" }
              }
            },
            {
              "type": "object",
              "required": ["type", "package"],
              "additionalProperties": false,
              "properties": {
                "type": { "const": "npm" },
                "package": { "type": "string", "minLength": 1 },
                "version": { "type": "string", "minLength": 1 }
              }
            }
          ]
        }
      }
    },
    "capabilityKind": {
      "type": "string",
      "enum": ["skill", "agent", "mcp"]
    },
    "mcpSpec": {
      "type": "object",
      "required": ["serverName", "transport", "sourceFormat", "config"],
      "additionalProperties": false,
      "properties": {
        "serverName": {
          "type": "string",
          "minLength": 1,
          "description": "Logical MCP server name."
        },
        "transport": {
          "type": "string",
          "enum": ["stdio", "remote"],
          "description": "MCP transport type."
        },
        "sourceFormat": {
          "type": "string",
          "enum": ["claude-local", "opencode", "claude-api", "direct"],
          "description": "Format of the MCP config source."
        },
        "config": {
          "type": "object",
          "description": "Transport-specific configuration. For stdio: requires 'command'. For remote: requires 'url'."
        }
      }
    },
    "capability": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable capability identifier. Should not change once published."
        },
        "kind": { "$ref": "#/$defs/capabilityKind" },
        "path": {
          "$ref": "#/$defs/relativePath",
          "description": "Path to the capability directory or file within the package source."
        },
        "entry": {
          "type": "string",
          "minLength": 1,
          "description": "Entry file name within the capability directory. Must not contain / or \\. Omit when path points to a known capability file."
        },
        "description": {
          "type": "string",
          "description": "User-facing description of what this capability does."
        },
        "spec": {
          "$ref": "#/$defs/mcpSpec",
          "description": "Inline MCP server specification. Required for virtual MCP capabilities. Mutually exclusive with path for MCP kind."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "enum": ["skill", "agent"] } } },
          "then": {
            "required": ["path"],
            "properties": { "spec": false }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "mcp" } } },
          "then": {
            "oneOf": [
              { "required": ["path"], "properties": { "spec": false } },
              { "required": ["spec"] }
            ]
          }
        }
      ]
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Environment variables required by this package."
        }
      }
    },
    "hookTarget": {
      "type": "string",
      "enum": ["claude", "opencode"]
    },
    "hookAppliesTo": {
      "type": "string",
      "pattern": "^(skill|agent):[A-Za-z0-9._-]+$",
      "description": "Scope selector in the form skill:<name> or agent:<name>."
    },
    "hookFileDeclaration": {
      "type": "object",
      "required": ["target", "path"],
      "additionalProperties": false,
      "properties": {
        "target": { "$ref": "#/$defs/hookTarget" },
        "path": { "$ref": "#/$defs/relativePath" }
      }
    },
    "hookDeclaration": {
      "type": "object",
      "required": ["id", "appliesTo", "files", "required"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "appliesTo": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/hookAppliesTo" }
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/hookFileDeclaration" },
          "description": "Hook files, one per target. No duplicate targets."
        },
        "required": {
          "type": "boolean",
          "description": "Whether this hook is required for the package to function."
        }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "const": "explicit",
          "description": "Hook declaration mode. Must be 'explicit'."
        },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/hookDeclaration" },
          "default": []
        }
      }
    },
    "advisory": {
      "type": "object",
      "required": ["id", "severity", "category", "message"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "category": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/relativePath" },
          "default": []
        },
        "reason": { "type": "string", "minLength": 1 },
        "effect": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 }
      }
    }
  }
}
